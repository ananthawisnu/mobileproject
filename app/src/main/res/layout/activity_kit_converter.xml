<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#022045"
    android:padding="24dp">

    <ImageButton
        android:id="@+id/btnHome"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_home"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:scaleType="fitCenter"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true" />

    <ImageView
        android:id="@+id/logoInstiki"
        android:layout_width="100dp"
        android:layout_height="wrap_content"
        android:src="@drawable/logo_instiki"
        android:adjustViewBounds="true"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Kit Converter"
            android:textColor="@android:color/white"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="48dp" />

        <GridLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="2"
            android:alignmentMode="alignMargins"
            android:columnOrderPreserved="false">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnPanjang"
                android:layout_width="140dp"
                android:layout_height="65dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_rounded_grey"
                android:text="Panjang"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnBMI"
                android:layout_width="140dp"
                android:layout_height="65dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_rounded_grey"
                android:text="BMI"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnMassa"
                android:layout_width="140dp"
                android:layout_height="65dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_rounded_grey"
                android:text="Massa"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/btnTemperatur"
                android:layout_width="140dp"
                android:layout_height="65dp"
                android:layout_margin="12dp"
                android:background="@drawable/bg_rounded_grey"
                android:text="Temperatur"
                android:textColor="@android:color/black"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"/>
        </GridLayout>

    </LinearLayout>
</RelativeLayout>